---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogList from '../../components/BlogList.astro';
import { estimateReadingTime } from '../../utils/readingTime';

const POSTS_PER_PAGE = 5;

export async function getStaticPaths() {
  const PER_PAGE = 5;
  const allPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true }));
  const totalPages = Math.ceil(allPosts.length / PER_PAGE);
  return Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map((page) => ({ params: { page: String(page) } }));
}

const { page } = Astro.params;
const currentPage = Number(page);

const allPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true }));
const sortedPosts = allPosts
  .map((post: any) => ({
    ...post,
    readingTime: estimateReadingTime(post.frontmatter.description),
  }))
  .sort((a: any, b: any) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());

const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const start = (currentPage - 1) * POSTS_PER_PAGE;
const pagePosts = sortedPosts.slice(start, start + POSTS_PER_PAGE);
const pageTitle = `Blogs - Page ${currentPage}`;
---

<BaseLayout pageTitle={pageTitle}>
  <p style="color:var(--color-text-muted);margin-bottom:1.5rem;">{sortedPosts.length} posts written · Page {currentPage} of {totalPages}</p>
  <BlogList posts={pagePosts} currentPage={currentPage} totalPages={totalPages} baseUrl="/blog/" />
</BaseLayout>