---
import BaseLayout from '../../layouts/BaseLayout.astro';
const allPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true }));
const allTags = allPosts.map((post: any) => post.frontmatter.tags).flat();
const tagCounts: Record<string, number> = {};
allTags.forEach((tag: string) => { tagCounts[tag] = (tagCounts[tag] || 0) + 1; });
const tags = [...new Set(allTags)].sort((a, b) => tagCounts[b] - tagCounts[a]);
const pageTitle = "Tags";
---
<BaseLayout pageTitle={pageTitle}>
  <p style="color:var(--color-text-muted);">Browse posts by tag — {tags.length} tags in total</p>
  <div class="tags">
    {tags.map((tag) => (
      <a class="tag" href={`/tags/${tag}`}>{tag} ({tagCounts[tag]})</a>
    ))}
  </div>
</BaseLayout>