---
import BaseLayout from '../layouts/BaseLayout.astro';
import { estimateReadingTime } from '../utils/readingTime';

const { frontmatter } = Astro.props;
const readingTime = estimateReadingTime(frontmatter.description);
---

<BaseLayout pageTitle={frontmatter.title}>
  <a href="javascript:history.back()" class="back-link">← Back</a>

  <article class="post-article">
    <div class="post-meta" style="display:flex;flex-wrap:wrap;gap:0.75rem;font-size:0.88rem;color:var(--color-text-muted);margin-bottom:1.5rem;">
      <span>{frontmatter.author}</span>
      <span>·</span>
      <span>{frontmatter.pubDate.toString().slice(0, 10)}</span>
      <span>·</span>
      <span>{readingTime} min read</span>
    </div>
    <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} />

    <div class="tags" style="margin:1rem 0;">
      {frontmatter.tags.map((tag: string) => (
        <a class="tag" href={`/tags/${tag}`}>{tag}</a>
      ))}
    </div>

    <slot />
  </article>
</BaseLayout>